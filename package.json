{
  "name": "project-daedalus",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite",
    "server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "setup:cesium": "node -e \"const {cpSync,mkdirSync}=require('fs'),b='node_modules/cesium/Build/Cesium';mkdirSync('public/cesium',{recursive:true});['Workers','ThirdParty','Assets','Widgets'].forEach(d=>cpSync(b+'/'+d,'public/cesium/'+d,{recursive:true}));console.log('Cesium assets copied to public/cesium/')\"",
    "postinstall": "npm run setup:cesium"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.6.0",
    "cesium": "^1.141.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fuse.js": "^7.4.0",
    "jspdf": "^4.2.1",
    "katex": "^0.17.0",
    "leaflet": "^1.9.4",
    "react": "^18.2.0",
    "react-datepicker": "^4.25.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.30.4",
    "recharts": "^2.9.0",
    "resium": "^1.22.0",
    "satellite.js": "^7.0.1",
    "winston": "^3.19.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.0"
  }
}
